DB_PATH=/var/lib/llm-gateway-student/students.db

UPSTREAM_BASE_URL=https://llm-internal.eva.univ-pau.fr
UPSTREAM_API_KEY=CHANGE_ME_INTERNAL_STUDENT_EDGE_KEY
UPSTREAM_CA_PATH=/etc/llm-gateway-student/ca-uppa.pem
UPSTREAM_CLIENT_CERT_PATH=/etc/llm-gateway-student/gw-student.crt
UPSTREAM_CLIENT_KEY_PATH=/etc/llm-gateway-student/gw-student.key

ALLOWED_MODELS=llama-3.1-8b-instruct,qwen-9b
DEFAULT_MODEL_ID=llama-3.1-8b-instruct

# Quotas par défaut appliqués à chaque nouvel étudiant
DEFAULT_RPM_LIMIT=10
DEFAULT_DAILY_TOKEN_LIMIT=100000
DEFAULT_HOURLY_TOKEN_LIMIT=20000    # 0 = désactivé
DEFAULT_CONCURRENT_STREAM_LIMIT=1

# Burst limiter : couche courte commune à tous (indépendant du RPM)
# Exemple : max 3 requêtes en 10 secondes empêche les rafales instantanées
BURST_LIMIT=3
BURST_WINDOW_SECONDS=10

MAX_BODY_BYTES=65536
MAX_PROMPT_CHARS=32768
MAX_MESSAGE_CHARS=8192
MAX_MESSAGES=32
MAX_TOOLS_BYTES=16384
MAX_COMPLETION_TOKENS=2048

AUDIT_HMAC_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
AUDIT_LOG_PATH=/var/log/llm-gateway-student/audit.jsonl
