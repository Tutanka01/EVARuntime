# LLM Gateway UPPA — Variables d'environnement
# Copier en .env (dev) ou /etc/llm-gateway/env (prod)
# Ne jamais committer ce fichier avec de vraies valeurs.

# ── Chemins ───────────────────────────────────────────────────────────────────
# Registre des modèles (YAML) — source de vérité multi-modèles
MODELS_CONFIG_PATH=/var/lib/llm-gateway/models.yaml
LLAMA_SERVER_BIN=/usr/local/bin/llama-server
DB_PATH=/var/lib/llm-gateway/gateway.db
LOG_DIR=/var/log/llm-gateway

# ── Modèle par défaut ─────────────────────────────────────────────────────────
# Utilisé si le client ne précise pas de champ "model" dans sa requête.
# Laisser vide pour utiliser automatiquement le premier modèle activé du registre.
DEFAULT_MODEL_ID=

# ── Budget VRAM multi-modèles (L40S 48 GB) ────────────────────────────────────
#
# Budget net = total_vram_gb - vram_overhead_gb - (total_vram_gb × vram_safety_margin)
# L40S 48 GB : 48 - 2 - 2.4 = 43.6 GB disponibles pour les modèles
#
# Les paramètres par modèle (ctx_size, parallel, etc.) se configurent dans models.yaml
#
TOTAL_VRAM_GB=48.0              # Capacité totale du GPU (nvidia-smi pour vérifier)
VRAM_OVERHEAD_GB=2.0            # Réservé : contexte CUDA + framework (~600 MB–2 GB)
VRAM_SAFETY_MARGIN=0.05         # 5% de marge supplémentaire (0.0 à 0.99)

# ── Pool de ports multi-modèles ────────────────────────────────────────────────
# Chaque llama-server chargé consomme un port du pool
# Pool : BASE_LLAMA_PORT … BASE_LLAMA_PORT + MAX_LOADED_MODELS - 1
BASE_LLAMA_PORT=8081
MAX_LOADED_MODELS=5             # Nombre max de modèles simultanément en VRAM

# ── Sécurité des chemins modèles ──────────────────────────────────────────────
# Liste de répertoires autorisés pour les fichiers .gguf (séparés par virgule)
# Vide = pas de restriction (tous répertoires absolus acceptés)
# Exemple : ALLOWED_MODEL_DIRS=/models,/data/models
ALLOWED_MODEL_DIRS=

# ── Lifecycle ─────────────────────────────────────────────────────────────────
IDLE_TIMEOUT_SECONDS=300        # décharger après 5 min sans requête
MODEL_LOAD_TIMEOUT_SECONDS=180  # timeout max pour le chargement d'un modèle
IDLE_CHECK_INTERVAL_SECONDS=30  # fréquence de vérification idle

# ── Queue d'admission VRAM ────────────────────────────────────────────────────
# Si un modèle ne peut pas être chargé car la VRAM/les ports sont temporairement
# occupés par des requêtes actives, attendre avant de retourner 503.
CAPACITY_QUEUE_ENABLED=true
CAPACITY_QUEUE_TIMEOUT_SECONDS=120
CAPACITY_QUEUE_MAX_WAITERS=100
CAPACITY_QUEUE_RETRY_AFTER_SECONDS=10

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT : les routes /admin sont DÉSACTIVÉES (503) tant qu'ADMIN_SECRET
# est vide ou laissé à une valeur CHANGE_ME_*.
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_KEY_BETWEEN_GATEWAY_AND_LLAMA_SERVER
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET_FOR_ADMIN_ENDPOINTS

# ── Réseau ────────────────────────────────────────────────────────────────────
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
LLAMA_SERVER_HOST=127.0.0.1     # Hôte partagé par tous les sous-processus llama-server

# ── Épinglage de version llama-server (mitigation supply-chain) ───────────────
# Build minimal accepté du binaire llama-server. 0 = pas d'enforcement (défaut).
# Recommandé : fixer au premier build patché contre GHSA-8947-pfff-2f3c
# (OOB write via n_discard/context-shift) + overflows de parsing GGUF.
# Si > 0 et binaire plus ancien → démarrage refusé ; version illisible → warning.
LLAMA_SERVER_MIN_BUILD=0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées pour les requêtes navigateur (séparées par des virgules).
# "*" convient en dev ; en production, restreindre aux domaines clients connus.
# Exemple : CORS_ALLOW_ORIGINS=https://app.univ-pau.fr,https://chat.univ-pau.fr
CORS_ALLOW_ORIGINS=*

# ── Rate limiting par défaut ───────────────────────────────────────────────────
DEFAULT_RPM_LIMIT=20            # 20 requêtes/minute par utilisateur
DEFAULT_MONTHLY_TOKEN_LIMIT=0   # 0 = illimité

# ── GPU ────────────────────────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0          # index GPU (0 = premier GPU)

# ── Cluster multi-nœuds (OPT-IN — avancé) ────────────────────────────────────
#
# Par défaut (CLUSTER_MODE=local) la gateway lance llama-server localement —
# c'est le mode utilisé en production UPPA depuis le départ. Aucune autre variable
# de cette section n'est lue.
#
# CLUSTER_MODE=cluster active le pilotage de plusieurs nœuds GPU distants. La
# gateway devient un orchestrateur sans GPU local et délègue les sous-processus
# à des agents (cf. node_agent/). Voir docs/deployment.md § Multi-nœud.
#
CLUSTER_MODE=local
CLUSTER_NODES_PATH=/etc/llm-gateway/nodes.yaml

# Secret bearer partagé orchestrateur ↔ agents. Doit être identique sur tous les
# nœuds. Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_SECRET=CHANGE_ME_AGENT_SECRET_SHARED_WITH_ALL_NODES

# Timeouts plan de contrôle (load/unload/health). Le chargement dispose d'un
# timeout séparé car un GGUF massif peut prendre plusieurs minutes.
CLUSTER_REQUEST_TIMEOUT=10.0
CLUSTER_LOAD_TIMEOUT=300.0
CLUSTER_HEALTH_INTERVAL=10
CLUSTER_HEALTH_FAILURES_TO_OFFLINE=3
