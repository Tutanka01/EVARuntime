# Exemple uniquement — les valeurs CHANGE_ME font échouer le démarrage.
NODE_ID=node-a
AGENT_HOST=0.0.0.0
AGENT_PORT=9443
AGENT_TLS_CERT=/etc/llm-gateway-agent/tls/agent.crt
AGENT_TLS_KEY=/etc/llm-gateway-agent/tls/agent.key
AGENT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARS

LLAMA_SERVER_BIN=/usr/local/bin/llama-server
LLAMA_SERVER_HOST=0.0.0.0
LLAMA_SERVER_HEALTH_HOST=127.0.0.1
BASE_LLAMA_PORT=8081
MAX_LOADED_MODELS=5
LLAMA_SERVER_MIN_BUILD=0
MODEL_LOAD_TIMEOUT_SECONDS=180
IDLE_CHECK_INTERVAL_SECONDS=10
INTERNAL_API_KEY=CHANGE_ME_GENERATE_ANOTHER_RANDOM_KEY_OF_AT_LEAST_32_CHARS

TOTAL_VRAM_GB=120.0
VRAM_OVERHEAD_GB=4.0
VRAM_SAFETY_MARGIN=0.03
ALLOWED_MODEL_DIRS=/models
CUDA_VISIBLE_DEVICES=0
LOG_DIR=/var/log/llm-gateway-agent
