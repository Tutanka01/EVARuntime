# LLM Gateway UPPA — Variables d'environnement
# Copier en .env (dev) ou /etc/llm-gateway/env (prod)
# Ne jamais committer ce fichier avec de vraies valeurs.

# ── Chemins ───────────────────────────────────────────────────────────────────
MODEL_PATH=/models/Llama-3.3-70B-Instruct-Q4_K_M.gguf
LLAMA_SERVER_BIN=/usr/local/bin/llama-server
DB_PATH=/var/lib/llm-gateway/gateway.db
LOG_DIR=/var/log/llm-gateway

# ── Modèle ────────────────────────────────────────────────────────────────────
MODEL_PUBLIC_NAME=llama-3.3-70b-instruct

# ── Paramètres llama-server (optimisés L40S 48GB + 70B Q4_K_M) ───────────────
#
# Budget VRAM estimé :
#   Poids modèle 70B Q4_K_M   : ~38-40 GB
#   KV cache (4 slots × 8K, Q8) : ~2.5 GB
#   Total                       : ~40.5 GB / 48 GB disponibles  ✓
#
LLAMA_N_GPU_LAYERS=999          # 999 = offloader toutes les couches GPU
LLAMA_CTX_SIZE=32768            # 4 slots × 8192 tokens chacun
LLAMA_PARALLEL=4                # slots d'inférence concurrents
LLAMA_BATCH_SIZE=4096           # batch logique prefill
LLAMA_UBATCH_SIZE=512           # micro-batch physique (doit être ≤ batch_size)
LLAMA_FLASH_ATTN=true           # Flash Attention 2 (Ada Lovelace = supporté)
LLAMA_CACHE_TYPE_K=q8_0         # KV cache quantisé : -50% VRAM, qualité identique
LLAMA_CACHE_TYPE_V=q8_0
LLAMA_THREADS=8                 # threads CPU génération (GPU fait le gros du travail)
LLAMA_THREADS_HTTP=4
CUDA_VISIBLE_DEVICES=0          # index GPU (0 = premier GPU)

# ── Lifecycle ─────────────────────────────────────────────────────────────────
IDLE_TIMEOUT_SECONDS=300        # décharger après 5 min sans requête
MODEL_LOAD_TIMEOUT_SECONDS=180  # timeout max pour le chargement du modèle
IDLE_CHECK_INTERVAL_SECONDS=30  # fréquence de vérification idle

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_KEY_BETWEEN_GATEWAY_AND_LLAMA_SERVER
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET_FOR_ADMIN_ENDPOINTS

# ── Réseau ────────────────────────────────────────────────────────────────────
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8081

# ── Rate limiting par défaut ───────────────────────────────────────────────────
DEFAULT_RPM_LIMIT=20            # 20 requêtes/minute par utilisateur
DEFAULT_MONTHLY_TOKEN_LIMIT=0   # 0 = illimité
